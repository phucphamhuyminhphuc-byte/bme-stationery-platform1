# BME Stationery Platform - Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_CDN_URL=https://cdn.bme-stationery.vn

# Map Services
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key_here

# Authentication
NEXTAUTH_SECRET=your_secret_key_here
NEXTAUTH_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bme_stationery

# File Upload
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
UPLOAD_DIR=/tmp/uploads

# AI/ML Services
OPENAI_API_KEY=your_openai_key_here
OCR_API_KEY=your_ocr_api_key_here

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Payment Gateway
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here

# Analytics
NEXT_PUBLIC_GA_ID=G-your_ga_id_here

# App Settings
NEXT_PUBLIC_APP_NAME=BME Stationery
NEXT_PUBLIC_APP_VERSION=1.0.0
NODE_ENV=development
